# Copy to .env and fill in real values. Never commit .env.
# Slack incoming webhook used by AlertManager and by the incident responder.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME/WITH_REAL_TOKEN
SLACK_CHANNEL=#nawex-alerts

# Kubernetes context used by the remediation scripts.
KUBE_CONTEXT=kind-nawex-platform
KUBE_NAMESPACE=nawex-platform

# Runbook base URL embedded in Slack alerts.
RUNBOOK_BASE_URL=https://github.com/Here2ServeU/nawex-hybrid-devops-platform/blob/main/runbooks

# Optional. If set, the responder posts approve/deny decisions back to Slack.
SLACK_BOT_TOKEN=
